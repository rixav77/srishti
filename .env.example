# ─── GROQ (Free LLM API) ───
GROQ_API_KEY=gsk_xxxxx

# ─── SUPABASE (Free PostgreSQL) ───
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJxxx
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres

# ─── PINECONE (Free Vector DB) ───
PINECONE_API_KEY=pcsk_xxxxx
PINECONE_INDEX_NAME=srishti

# ─── UPSTASH REDIS (Free Cache) ───
REDIS_URL=redis://default:xxxxx@xxxxx.upstash.io:6379

# ─── EMBEDDINGS (Local - no key needed) ───
EMBEDDING_MODEL=BAAI/bge-m3

# ─── TICKETMASTER (Free API - 5000 calls/day) ───
# Register at: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=xxxxx

# ─── LUMA (Optional - requires Luma Plus subscription) ───
# Without this key, luma.py falls back to CSS scraping of public discover pages
LUMA_API_KEY=
